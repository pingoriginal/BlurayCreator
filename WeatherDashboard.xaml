<Window x:Class="BlurayCreator.WeatherDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather Dashboard" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <StackPanel>
                <TextBlock Text="🌍 Weather Dashboard" FontSize="28" FontWeight="Bold" 
                           Foreground="White" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="CityInput" Width="300" Height="40" Padding="10"
                             FontSize="14" PlaceholderText="Enter city name..."
                             Background="White" Foreground="#333333"/>
                    <Button x:Name="SearchButton" Content="Search" Click="SearchButton_Click"
                           Width="100" Height="40" Margin="10,0,0,0"
                           Background="#3498DB" Foreground="White" FontSize="14" FontWeight="Bold"
                           Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel x:Name="ContentPanel">
                <!-- Weather Info Card -->
                <Border x:Name="WeatherCard" Background="White" CornerRadius="10" 
                        Padding="20" Margin="0,0,0,20" Visibility="Hidden"
                        Effect="{StaticResource DropShadowEffect}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Weather Icon -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,30,0">
                            <TextBlock x:Name="WeatherIcon" FontSize="80" TextAlignment="Center"/>
                            <TextBlock x:Name="WeatherDescription" FontSize="16" 
                                       Foreground="#7F8C8D" TextAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Middle: Main Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="CityName" FontSize="36" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <TextBlock FontSize="18" Foreground="#7F8C8D" Margin="0,0,0,5">
                                <Run Text="Updated: "/>
                                <Run x:Name="UpdateTime" Text="--:--:--"/>
                            </TextBlock>
                            <TextBlock x:Name="Coordinates" FontSize="12" Foreground="#95A5A6"/>
                        </StackPanel>

                        <!-- Right: Temperature -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock x:Name="Temperature" FontSize="72" FontWeight="Bold" 
                                       Foreground="#E74C3C" TextAlignment="Right"/>
                            <TextBlock FontSize="16" Foreground="#7F8C8D" TextAlignment="Right">°C</TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Details Grid -->
                <Grid x:Name="DetailsGrid" Visibility="Hidden">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Humidity Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0"
                           Effect="{StaticResource DropShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="💧 Humidity" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <TextBlock x:Name="Humidity" FontSize="24" FontWeight="Bold" 
                                       Foreground="#3498DB"/>
                            <TextBlock Text="%" FontSize="12" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>

                    <!-- Wind Speed Card -->
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0"
                           Effect="{StaticResource DropShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="💨 Wind Speed" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <TextBlock x:Name="WindSpeed" FontSize="24" FontWeight="Bold" 
                                       Foreground="#27AE60"/>
                            <TextBlock Text="m/s" FontSize="12" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>

                    <!-- Pressure Card -->
                    <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0"
                           Effect="{StaticResource DropShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="🔘 Pressure" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <TextBlock x:Name="Pressure" FontSize="24" FontWeight="Bold" 
                                       Foreground="#E67E22"/>
                            <TextBlock Text="hPa" FontSize="12" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>

                    <!-- Visibility Card -->
                    <Border Grid.Column="3" Background="White" CornerRadius="10" Padding="15"
                           Effect="{StaticResource DropShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="👁️ Visibility" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <TextBlock x:Name="Visibility" FontSize="24" FontWeight="Bold" 
                                       Foreground="#9B59B6"/>
                            <TextBlock Text="km" FontSize="12" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Extra Details -->
                <Grid x:Name="ExtraDetailsGrid" Visibility="Hidden" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Feels Like Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0"
                           Effect="{StaticResource DropShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="🌡️ Feels Like" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <TextBlock x:Name="FeelsLike" FontSize="24" FontWeight="Bold" 
                                       Foreground="#E74C3C"/>
                            <TextBlock Text="°C" FontSize="12" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>

                    <!-- Min/Max Temp Card -->
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0"
                           Effect="{StaticResource DropShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="📊 Min/Max" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="12" Foreground="#3498DB" Margin="0,0,10,0">
                                    <Run Text="Min: "/>
                                    <Run x:Name="TempMin" Text="--"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#E74C3C">
                                    <Run Text="Max: "/>
                                    <Run x:Name="TempMax" Text="--"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Cloudiness Card -->
                    <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="15"
                           Effect="{StaticResource DropShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="☁️ Cloudiness" FontSize="14" FontWeight="Bold" 
                                       Foreground="#2C3E50" Margin="0,0,0,10"/>
                            <TextBlock x:Name="Cloudiness" FontSize="24" FontWeight="Bold" 
                                       Foreground="#95A5A6"/>
                            <TextBlock Text="%" FontSize="12" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Error Message -->
                <Border x:Name="ErrorBorder" Background="#FADBD8" CornerRadius="10" Padding="15" Visibility="Hidden" Margin="0,20,0,0">
                    <TextBlock x:Name="ErrorMessage" Foreground="#C0392B" FontSize="14"/>
                </Border>

                <!-- Loading Indicator -->
                <Border x:Name="LoadingBorder" Background="#D5DBDB" CornerRadius="10" Padding="20" 
                        Visibility="Hidden" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="⏳ Loading weather data..." FontSize="16" Foreground="#2C3E50" FontWeight="Bold"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Window.Resources>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
    </Window.Resources>
</Window>
