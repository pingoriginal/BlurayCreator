<Window x:Class="BlurayCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Blu-ray Creator" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2C3E50" VerticalAlignment="Center">
            <Button Content="Import Video" Click="ImportVideo_Click" 
                    Background="#3498DB" Foreground="White" 
                    Padding="15,10" Margin="10,0" FontSize="14" FontWeight="Bold"/>
            <Button Content="Add Audio Track" Click="AddAudio_Click" 
                    Background="#3498DB" Foreground="White" 
                    Padding="15,10" Margin="5,0" FontSize="14" FontWeight="Bold"/>
            <Button Content="Add Subtitle" Click="AddSubtitle_Click" 
                    Background="#3498DB" Foreground="White" 
                    Padding="15,10" Margin="5,0" FontSize="14" FontWeight="Bold"/>
            <Button Content="Preview" Click="Preview_Click" 
                    Background="#27AE60" Foreground="White" 
                    Padding="15,10" Margin="5,0" FontSize="14" FontWeight="Bold"/>
            <Button Content="Burn Disc" Click="BurnDisc_Click" 
                    Background="#E74C3C" Foreground="White" 
                    Padding="15,10" Margin="5,0" FontSize="14" FontWeight="Bold"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - File List -->
            <StackPanel Grid.Column="0" Background="White" Margin="0,0,10,0">
                <TextBlock Text="Project Files" FontSize="16" FontWeight="Bold" Margin="10,10,10,5" Foreground="#2C3E50"/>
                <ListBox x:Name="FileList" Margin="10" Height="400" Background="#ECF0F1">
                    <ListBoxItem>No files loaded yet...</ListBoxItem>
                </ListBox>
            </StackPanel>

            <!-- Right Panel - Preview & Info -->
            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <!-- Video Preview -->
                <StackPanel Grid.Row="0" Background="#34495E" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Video Preview" Foreground="White" FontSize="18" TextAlignment="Center" Margin="0,20"/>
                    <Rectangle Width="400" Height="300" Fill="#2C3E50" Margin="0,10"/>
                    <TextBlock Text="No video loaded" Foreground="#BDC3C7" FontSize="12" TextAlignment="Center" Margin="0,10,0,20"/>
                </StackPanel>

                <!-- Info Panel -->
                <StackPanel Grid.Row="1" Background="#ECF0F1" Margin="10">
                    <TextBlock Text="Project Information" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,5"/>
                    <TextBlock x:Name="InfoText" Text="Project: New Project&#xA;Video: Not loaded&#xA;Duration: --:--:--&#xA;Resolution: N/A&#xA;Frame Rate: N/A" 
                               Foreground="#34495E" FontSize="11" Margin="0,5" LineHeight="18"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Background="#2C3E50" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="White" Margin="15,0" VerticalAlignment="Center" FontSize="12"/>
            <ProgressBar x:Name="ProgressBar" Width="300" Height="20" Margin="10,0" Background="#ECF0F1" Foreground="#27AE60"/>
        </StackPanel>
    </Grid>
</Window>
