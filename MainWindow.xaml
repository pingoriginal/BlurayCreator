<Window x:Class="BlurayCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blu-ray Creator" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2C3E50" Padding="10">
            <Button x:Name="BtnImport" Content="Import Video" Click="ImportVideo_Click" 
                    Background="#3498DB" Foreground="White" Padding="15,10" Margin="5"
                    Width="110" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
            <Button x:Name="BtnAudio" Content="Add Audio" Click="AddAudio_Click" 
                    Background="#3498DB" Foreground="White" Padding="15,10" Margin="5"
                    Width="110" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
            <Button x:Name="BtnSubtitle" Content="Add Subtitle" Click="AddSubtitle_Click" 
                    Background="#3498DB" Foreground="White" Padding="15,10" Margin="5"
                    Width="110" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
            <Button x:Name="BtnPreview" Content="Preview" Click="Preview_Click" 
                    Background="#27AE60" Foreground="White" Padding="15,10" Margin="5"
                    Width="110" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
            <Button x:Name="BtnBurn" Content="Burn Disc" Click="BurnDisc_Click" 
                    Background="#E74C3C" Foreground="White" Padding="15,10" Margin="5"
                    Width="110" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" Background="White" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Project Files" FontSize="13" FontWeight="Bold" 
                               Foreground="#2C3E50" Padding="10,10,10,5"/>
                    <Border Height="1" Background="#3498DB" Margin="10,0,10,10"/>
                    <ListBox x:Name="FileList" Margin="10" Background="White" 
                             Foreground="#333333" BorderThickness="0">
                        <ListBoxItem Foreground="#999999">No files loaded</ListBoxItem>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Right Panel -->
            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <!-- Video Preview -->
                <Border Grid.Row="0" Background="#34495E" Padding="20" Margin="0,0,0,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Video Preview" Foreground="White" FontSize="14" 
                                   TextAlignment="Center" Margin="0,0,0,15" FontWeight="Bold"/>
                        <Rectangle Width="350" Height="200" Fill="#2C3E50" 
                                   Stroke="#555555" StrokeThickness="2"/>
                        <TextBlock Text="No video loaded" Foreground="#BDC3C7" FontSize="11" 
                                   TextAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Project Info -->
                <Border Grid.Row="1" Background="#F9F9F9" BorderBrush="#CCCCCC" 
                        BorderThickness="0,1,0,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Project Information" FontSize="11" FontWeight="Bold" 
                                   Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <TextBlock x:Name="InfoText" 
                                   Text="Video: Not loaded | Duration: --:--:-- | Resolution: N/A" 
                                   Foreground="#555555" FontSize="10" TextWrapping="Wrap" LineHeight="16"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Background="#34495E" Padding="10">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="#27AE60" 
                       VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
            <ProgressBar x:Name="ProgressBar" Width="300" Height="12" Margin="20,0,0,0" 
                         Background="#555555" Foreground="#27AE60" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
