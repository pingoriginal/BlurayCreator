<Window x:Class="BlurayCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blu-ray Creator" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <DockPanel LastChildFill="True">
        
        <!-- Top Menu Bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2C3E50" Height="70" Margin="0" Padding="10">
            <Button Content="Import Video" Click="ImportVideo_Click" 
                    Background="#3498DB" Foreground="White" 
                    Width="120" Height="50" Margin="5" FontSize="12" FontWeight="Bold"/>
            <Button Content="Add Audio" Click="AddAudio_Click" 
                    Background="#3498DB" Foreground="White" 
                    Width="120" Height="50" Margin="5" FontSize="12" FontWeight="Bold"/>
            <Button Content="Add Subtitle" Click="AddSubtitle_Click" 
                    Background="#3498DB" Foreground="White" 
                    Width="120" Height="50" Margin="5" FontSize="12" FontWeight="Bold"/>
            <Button Content="Preview" Click="Preview_Click" 
                    Background="#27AE60" Foreground="White" 
                    Width="120" Height="50" Margin="5" FontSize="12" FontWeight="Bold"/>
            <Button Content="Burn Disc" Click="BurnDisc_Click" 
                    Background="#E74C3C" Foreground="White" 
                    Width="120" Height="50" Margin="5" FontSize="12" FontWeight="Bold"/>
        </StackPanel>

        <!-- Bottom Status Bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Background="#34495E" Height="50" Margin="0" Padding="10">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="#27AE60" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Margin="0,0,20,0"/>
            <ProgressBar x:Name="ProgressBar" Width="300" Height="15" Background="#555555" Foreground="#27AE60" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Background="White" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Project Files -->
            <StackPanel Grid.Column="0" Background="#F5F5F5" Margin="0,0,10,0">
                <TextBlock Text="Project Files" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Padding="10,10,10,5"/>
                <Border Height="2" Background="#3498DB" Margin="10,0,10,10"/>
                <ListBox x:Name="FileList" Margin="10" Background="White" Foreground="#333333">
                    <ListBoxItem Foreground="#999999">No files loaded</ListBoxItem>
                </ListBox>
            </StackPanel>

            <!-- Right Panel: Preview and Info -->
            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <!-- Video Preview Section -->
                <Border Grid.Row="0" Background="#34495E" Padding="20" Margin="0,0,0,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Video Preview" Foreground="White" FontSize="16" TextAlignment="Center" Margin="0,0,0,15" FontWeight="Bold"/>
                        <Rectangle Width="400" Height="250" Fill="#2C3E50" Stroke="#555555" StrokeThickness="2"/>
                        <TextBlock Text="No video loaded" Foreground="#BDC3C7" FontSize="12" TextAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border Grid.Row="1" Height="2" Background="#DDDDDD"/>

                <!-- Project Info Section -->
                <StackPanel Grid.Row="2" Background="#F9F9F9" Padding="15" Margin="0,10,0,0">
                    <TextBlock Text="Project Information" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <TextBlock x:Name="InfoText" Text="Video: Not loaded | Duration: --:--:-- | Resolution: N/A | Frame Rate: N/A" 
                               Foreground="#555555" FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
