<Window x:Class="BlurayCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blu-ray Creator" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <DockPanel>
        <!-- Top Menu Bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2C3E50" Height="60" Margin="0">
            <Button Content="📁 Import Video" Click="ImportVideo_Click" 
                    Background="#3498DB" Foreground="White" 
                    Padding="20,15" Margin="10" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="🔊 Add Audio" Click="AddAudio_Click" 
                    Background="#3498DB" Foreground="White" 
                    Padding="20,15" Margin="5,10" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="📝 Add Subtitle" Click="AddSubtitle_Click" 
                    Background="#3498DB" Foreground="White" 
                    Padding="20,15" Margin="5,10" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="👁️ Preview" Click="Preview_Click" 
                    Background="#27AE60" Foreground="White" 
                    Padding="20,15" Margin="5,10" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="💿 Burn Disc" Click="BurnDisc_Click" 
                    Background="#E74C3C" Foreground="White" 
                    Padding="20,15" Margin="5,10" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>

        <!-- Bottom Status Bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Background="#2C3E50" Height="45" Margin="0">
            <TextBlock x:Name="StatusText" Text="✓ Ready" Foreground="#27AE60" Margin="15,0" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
            <ProgressBar x:Name="ProgressBar" Width="400" Height="15" Margin="20,0" Background="#ECF0F1" Foreground="#27AE60"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Background="White" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: File List Panel -->
            <Border Grid.Column="0" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="📂 Project Files" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Padding="10,10,10,5"/>
                    <Border Height="1" Background="#CCCCCC" Margin="10,0"/>
                    <ListBox x:Name="FileList" Margin="10" Background="#F9F9F9" Foreground="#333333">
                        <ListBoxItem Foreground="#999999">No files loaded yet...</ListBoxItem>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Right: Preview & Info Panel -->
            <Border Grid.Column="1" Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="1" Background="#CCCCCC"/>
                        <RowDefinition Height="140"/>
                    </Grid.RowDefinitions>

                    <!-- Video Preview Area -->
                    <Border Grid.Row="0" Background="#34495E" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🎬 Video Preview" Foreground="White" FontSize="16" TextAlignment="Center" Margin="0,0,0,10" FontWeight="Bold"/>
                            <Rectangle Width="350" Height="220" Fill="#2C3E50" Stroke="#555555" StrokeThickness="2" Margin="0,10"/>
                            <TextBlock Text="Load a video to see preview" Foreground="#BDC3C7" FontSize="11" TextAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Info Panel -->
                    <StackPanel Grid.Row="2" Background="#ECF0F1" Padding="15">
                        <TextBlock Text="ℹ️ Project Information" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                        <TextBlock x:Name="InfoText" 
                                   Text="Video: Not loaded | Duration: --:--:-- | Resolution: N/A | Frame Rate: N/A" 
                                   Foreground="#555555" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
